# ── LORE backend ────────────────────────────────────────────────
# これ1本を本物のキーにすれば実LLMで動く。未設定なら mock モードで起動。
DEEPSEEK_API_KEY=

# OpenAI互換エンドポイント（DeepSeek）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# モデルID（env で差し替え可能）
LLM_MODEL_PRO=deepseek-chat       # 「いいLLM」: 言い当て・コンテンツ生成
LLM_MODEL_FLASH=deepseek-chat     # 「安いLLM」: 会話・採点・候補・選定

# DB（SQLite ファイル）
DATABASE_FILE=./lore.db

# サーバ
PORT=8787
# FE(LORE.dc.html) を開くオリジン。* で全許可（ローカル開発用）
CORS_ORIGIN=*
