# ══════════════════════════════════════════════════════════════════
#  LORE backend — env テンプレート
#  Convex の環境変数として設定する（`npx convex env set KEY value` か
#  Convex ダッシュボードの Settings > Environment Variables）。
#  各サービスのキーを入れた分だけ、その機能が有効化される（graceful degrade）。
# ══════════════════════════════════════════════════════════════════

# ── LLM: DeepSeek（OpenAI互換）──────────────────────────────────
# 未設定なら mock モード（キー無しで会話・生成が動く）。挿せば実LLMに自動切替。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL_PRO=deepseek-chat       # いいLLM: 言い当て(strike)・コンテンツ生成
LLM_MODEL_FLASH=deepseek-chat     # 安いLLM: 会話・採点・候補・選定

# ── 認証: Clerk ─────────────────────────────────────────────────
# Clerk の Frontend API URL（例 https://verb-noun-00.clerk.accounts.dev）。
# convex/auth.config.ts が参照。JWTテンプレート名は "convex"。
CLERK_FRONTEND_API_URL=
# 未設定 + ALLOW_DEV_USER=1 で、認証なしのデモユーザー(@maruyama)にフォールバック。
ALLOW_DEV_USER=1

# ── Web決済: Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APP_WEB_URL=http://localhost:3000   # checkout の success/cancel 戻り先

# ── モバイル決済: RevenueCat（権利の真実の源）──────────────────
# RC ダッシュボードの Webhook に設定する Authorization ヘッダ値と一致させる。
REVENUECAT_WEBHOOK_AUTH=

# ── 分析: PostHog（サーバー側 capture。クライアントは別途SDK）──
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
